<%- include("partials/admin-start", { pageTitle }) %>

<section class="stat-grid" aria-label="Dashboard statistics">
  <article class="stat-card">
    <span>Total Customers</span>
    <strong><%= stats.totalCustomers.toLocaleString("en-IN") %></strong>
  </article>
  <article class="stat-card">
    <span>Total Campaigns</span>
    <strong><%= stats.totalCampaigns.toLocaleString("en-IN") %></strong>
  </article>
  <article class="stat-card">
    <span>Messages Sent</span>
    <strong><%= stats.messagesSent.toLocaleString("en-IN") %></strong>
  </article>
  <article class="stat-card">
    <span>Consultation Requests</span>
    <strong><%= stats.consultationRequests.toLocaleString("en-IN") %></strong>
  </article>
  <article class="stat-card">
    <span>Product Enquiries</span>
    <strong><%= stats.productEnquiries.toLocaleString("en-IN") %></strong>
  </article>
  <article class="stat-card">
    <span>Offer Campaigns</span>
    <strong><%= stats.offerCampaigns.toLocaleString("en-IN") %></strong>
  </article>
</section>

<section class="panel action-panel">
  <div>
    <p class="eyebrow">Ready to glow?</p>
    <h2>Create a <%= brand.shortName %> skincare campaign</h2>
    <p class="muted">Use approved WhatsApp templates for launches, offers, reminders, and follow-ups.</p>
  </div>
  <a class="button button-primary" href="/admin/bulk-messages">Send Bulk Message</a>
</section>

<%- include("partials/admin-end") %>
