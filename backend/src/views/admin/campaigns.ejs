<%- include("partials/admin-start", { pageTitle }) %>

<section class="panel">
  <div class="section-heading">
    <div>
      <h2>Campaign history</h2>
      <p class="muted">Approved WhatsApp templates sent to opted-in <%= brand.shortName %> customers.</p>
    </div>
    <a class="button button-primary" href="/admin/campaigns/new">New campaign</a>
  </div>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Title</th>
          <th>Template</th>
          <th>Status</th>
          <th>Recipients</th>
          <th>Sent</th>
          <th>Failed</th>
          <th>Created</th>
        </tr>
      </thead>
      <tbody>
        <% if (!campaigns.length) { %>
          <tr><td colspan="7" class="empty">No campaigns have been sent.</td></tr>
        <% } %>
        <% campaigns.forEach((campaign) => { %>
          <tr>
            <td><a class="table-link" href="/admin/campaigns/<%= campaign._id %>"><%= campaign.title %></a></td>
            <td><code><%= campaign.templateName %></code></td>
            <td><span class="badge badge-<%= campaign.status === 'completed' ? 'success' : campaign.status === 'failed' ? 'danger' : 'warning' %>"><%= campaign.status.replaceAll("_", " ") %></span></td>
            <td><%= campaign.totalRecipients %></td>
            <td><%= campaign.sentCount %></td>
            <td><%= campaign.failedCount %></td>
            <td><%= formatDate(campaign.createdAt) %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</section>

<%- include("partials/admin-end") %>
